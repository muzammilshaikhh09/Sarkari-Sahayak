const AGE_FILTERS = [
  { id: "all", label: "All Citizens" },
  { id: "student", label: "Students" },
  { id: "adult", label: "Adults (18+)" },
  { id: "senior", label: "Senior Citizens" },
];

export default function SarkariSahayak() {
  const [search, setSearch] = useState("");
  const [activeCat, setActiveCat] = useState("all");
  const [activeAge, setActiveAge] = useState("all");
  const [bookmarks, setBookmarks] = useState([]);
  const [showBookmarks, setShowBookmarks] = useState(false);
  const [darkMode, setDarkMode] = useState(false);

  const toggleBookmark = (id) => {
    setBookmarks((prev) =>
      prev.includes(id) ? prev.filter((b) => b !== id) : [...prev, id]
    );
  };

  const filtered = useMemo(() => {
    let list = showBookmarks ? SERVICES.filter((s) => bookmarks.includes(s.id)) : SERVICES;
    if (activeCat !== "all") list = list.filter((s) => s.cat === activeCat);
    if (activeAge !== "all") list = list.filter((s) => s.age === activeAge || s.age === "all");
    if (search.trim()) {
      const q = search.toLowerCase();
      list = list.filter(
        (s) =>
          s.title.toLowerCase().includes(q) ||
          s.desc.toLowerCase().includes(q) ||
          s.tag.toLowerCase().includes(q)
      );
    }
    return list;
  }, [search, activeCat, activeAge, bookmarks, showBookmarks]);

  const theme = {
    bg: darkMode ? "#0f1117" : "#f5f7fa",
    card: darkMode ? "#1a1d27" : "#ffffff",
    text: darkMode ? "#e8eaf0" : "#1a1d2e",
    sub: darkMode ? "#8b90a8" : "#6b7280",
    border: darkMode ? "#2a2d3e" : "#e4e7ed",
    accent: "#1a56db",
    accentLight: darkMode ? "#1e3a8a22" : "#eff6ff",
    headerBg: darkMode ? "#1a1d27" : "#ffffff",
    pill: darkMode ? "#1e2235" : "#f0f4ff",
    pillText: darkMode ? "#a5b4fc" : "#3b4fd8",
    pillBorder: darkMode ? "#2e3460" : "#c7d2fe",
  };

  return (
    <div style={{ minHeight: "100vh", background: theme.bg, fontFamily: "'Noto Sans', 'Hind', sans-serif", color: theme.text, transition: "background 0.3s, color 0.3s" }}>
      {/* Header */}
      <header style={{ background: theme.headerBg, borderBottom: `1px solid ${theme.border}`, position: "sticky", top: 0, zIndex: 100, boxShadow: darkMode ? "none" : "0 1px 8px #0001" }}>
        <div style={{ maxWidth: 1100, margin: "0 auto", padding: "0 1.5rem", display: "flex", alignItems: "center", justifyContent: "space-between", height: 64 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
            <div style={{ width: 36, height: 36, borderRadius: 8, background: "linear-gradient(135deg,#1a56db,#0ea5e9)", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18 }}>🇮🇳</div>
            <div>
              <div style={{ fontWeight: 700, fontSize: 18, letterSpacing: "-0.3px", color: theme.text }}>Sarkari Sahayak</div>
              <div style={{ fontSize: 11, color: theme.sub }}>Government Services Navigator</div>
            </div>
          </div>
          <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
            <button
              onClick={() => { setShowBookmarks(!showBookmarks); setActiveCat("all"); }}
              style={{ padding: "6px 14px", borderRadius: 8, border: `1px solid ${showBookmarks ? theme.accent : theme.border}`, background: showBookmarks ? theme.accentLight : "transparent", color: showBookmarks ? theme.accent : theme.sub, cursor: "pointer", fontSize: 13, fontWeight: 500, transition: "all 0.2s" }}
            >
              🔖 Saved ({bookmarks.length})
            </button>
            <button
              onClick={() => setDarkMode(!darkMode)}
              style={{ padding: "6px 12px", borderRadius: 8, border: `1px solid ${theme.border}`, background: "transparent", color: theme.sub, cursor: "pointer", fontSize: 16 }}
              aria-label="Toggle dark mode"
            >
              {darkMode ? "☀️" : "🌙"}
            </button>
          </div>
        </div>
      </header>

      {/* Disclaimer */}
      <div style={{ background: "#fef3c7", borderBottom: "1px solid #fde68a", padding: "8px 1.5rem", textAlign: "center", fontSize: 12.5, color: "#92400e" }}>
        {DISCLAIMER}
      </div>

      {/* Hero Search */}
      <div style={{ background: "linear-gradient(135deg, #1e3a8a 0%, #1d4ed8 50%, #0284c7 100%)", padding: "2.5rem 1.5rem 3rem" }}>
        <div style={{ maxWidth: 680, margin: "0 auto", textAlign: "center" }}>
          <h1 style={{ margin: "0 0 0.5rem", fontSize: 28, fontWeight: 700, color: "#fff", letterSpacing: "-0.5px" }}>
            Find Any Government Service
          </h1>
          <p style={{ margin: "0 0 1.5rem", color: "#bfdbfe", fontSize: 15 }}>
            Aadhaar, PAN, Passport, Scholarships, Farm Schemes & 40+ more — all official links in one place
          </p>
          <div style={{ position: "relative" }}>
            <span style={{ position: "absolute", left: 16, top: "50%", transform: "translateY(-50%)", fontSize: 18 }}>🔍</span>
            <input
              value={search}
              onChange={(e) => { setSearch(e.target.value); setShowBookmarks(false); setActiveCat("all"); }}
              placeholder="Search: 'passport', 'scholarship', 'EPF', 'GST'..."
              style={{ width: "100%", boxSizing: "border-box", padding: "14px 16px 14px 46px", borderRadius: 12, border: "none", fontSize: 15, outline: "none", background: "#fff", color: "#1a1d2e", boxShadow: "0 4px 20px #0003" }}
            />
          </div>
        </div>
      </div>

      {/* Age Filter */}
      <div style={{ background: theme.card, borderBottom: `1px solid ${theme.border}` }}>
        <div style={{ maxWidth: 1100, margin: "0 auto", padding: "10px 1.5rem", display: "flex", gap: 8, overflowX: "auto", alignItems: "center" }}>
          <span style={{ fontSize: 12, color: theme.sub, whiteSpace: "nowrap", marginRight: 4 }}>I am a:</span>
          {AGE_FILTERS.map((f) => (
            <button
              key={f.id}
              onClick={() => setActiveAge(f.id)}
              style={{ padding: "5px 14px", borderRadius: 20, border: `1px solid ${activeAge === f.id ? theme.accent : theme.border}`, background: activeAge === f.id ? theme.accent : "transparent", color: activeAge === f.id ? "#fff" : theme.sub, cursor: "pointer", fontSize: 13, fontWeight: 500, whiteSpace: "nowrap", transition: "all 0.2s" }}
            >
              {f.label}
            </button>
          ))}
        </div>
      </div>

      <div style={{ maxWidth: 1100, margin: "0 auto", padding: "1.5rem 1.5rem 4rem" }}>
        {/* Category Grid */}
        {!search && !showBookmarks && (
          <div style={{ marginBottom: "1.5rem" }}>
            <h2 style={{ fontSize: 14, fontWeight: 600, color: theme.sub, textTransform: "uppercase", letterSpacing: "0.05em", marginBottom: "0.75rem" }}>Browse by Category</h2>
            <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(140px, 1fr))", gap: 8 }}>
              <button
                onClick={() => setActiveCat("all")}
                style={{ padding: "10px 12px", borderRadius: 10, border: `1px solid ${activeCat === "all" ? theme.accent : theme.border}`, background: activeCat === "all" ? theme.accentLight : theme.card, cursor: "pointer", textAlign: "left", transition: "all 0.2s" }}
              >
                <div style={{ fontSize: 20 }}>🏛️</div>
                <div style={{ fontSize: 12.5, fontWeight: 600, color: activeCat === "all" ? theme.accent : theme.text, marginTop: 4 }}>All Services</div>
              </button>
              {CATEGORIES.map((c) => (
                <button
                  key={c.id}
                  onClick={() => setActiveCat(c.id)}
                  style={{ padding: "10px 12px", borderRadius: 10, border: `1px solid ${activeCat === c.id ? theme.accent : theme.border}`, background: activeCat === c.id ? theme.accentLight : theme.card, cursor: "pointer", textAlign: "left", transition: "all 0.2s" }}
                >
                  <div style={{ fontSize: 20 }}>{c.icon}</div>
                  <div style={{ fontSize: 12.5, fontWeight: 600, color: activeCat === c.id ? theme.accent : theme.text, marginTop: 4, lineHeight: 1.3 }}>{c.label}</div>
                </button>
              ))}
            </div>
          </div>
        )}

        {/* Results Header */}
        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: "0.75rem" }}>
          <h2 style={{ fontSize: 14, fontWeight: 600, color: theme.sub, textTransform: "uppercase", letterSpacing: "0.05em", margin: 0 }}>
            {showBookmarks ? "Saved Services" : search ? `Results for "${search}"` : activeCat === "all" ? "All Services" : CATEGORIES.find(c => c.id === activeCat)?.label}
            <span style={{ marginLeft: 8, fontWeight: 400, textTransform: "none", letterSpacing: 0 }}>({filtered.length})</span>
          </h2>
        </div>

        {/* Service Cards */}
        {filtered.length === 0 ? (
          <div style={{ textAlign: "center", padding: "3rem", color: theme.sub }}>
            <div style={{ fontSize: 40 }}>🔍</div>
            <p>No services found. Try a different search.</p>
          </div>
        ) : (
          <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(300px, 1fr))", gap: 12 }}>
            {filtered.map((s) => {
              const saved = bookmarks.includes(s.id);
              const cat = CATEGORIES.find(c => c.id === s.cat);
              return (
                <div
                  key={s.id}
                  style={{ background: theme.card, border: `1px solid ${theme.border}`, borderRadius: 12, padding: "1rem 1.1rem", display: "flex", flexDirection: "column", gap: 8, transition: "box-shadow 0.2s", cursor: "default" }}
                  onMouseEnter={e => e.currentTarget.style.boxShadow = darkMode ? "0 0 0 1px #2a2d3e" : "0 4px 18px #1a56db18"}
                  onMouseLeave={e => e.currentTarget.style.boxShadow = "none"}
                >
                  <div style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between", gap: 8 }}>
                    <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                      <span style={{ fontSize: 18 }}>{cat?.icon}</span>
                      <span style={{ fontSize: 11, fontWeight: 600, padding: "2px 8px", borderRadius: 20, background: theme.pill, color: theme.pillText, border: `1px solid ${theme.pillBorder}` }}>{s.tag}</span>
                    </div>
                    <button
                      onClick={() => toggleBookmark(s.id)}
                      style={{ background: "none", border: "none", cursor: "pointer", fontSize: 18, color: saved ? "#f59e0b" : theme.sub, flexShrink: 0, padding: 0, lineHeight: 1 }}
                      aria-label={saved ? "Remove bookmark" : "Bookmark"}
                    >
                      {saved ? "🔖" : "🏷️"}
                    </button>
                  </div>
                  <div>
                    <div style={{ fontWeight: 700, fontSize: 14.5, color: theme.text, marginBottom: 4 }}>{s.title}</div>
                    <div style={{ fontSize: 13, color: theme.sub, lineHeight: 1.55 }}>{s.desc}</div>
                  </div>
                  <a
                    href={s.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    style={{ display: "inline-flex", alignItems: "center", gap: 6, marginTop: "auto", padding: "8px 14px", borderRadius: 8, background: "#1a56db", color: "#fff", fontSize: 13, fontWeight: 600, textDecoration: "none", border: "none", transition: "background 0.2s", alignSelf: "flex-start" }}
                    onMouseEnter={e => e.currentTarget.style.background = "#1d4ed8"}
                    onMouseLeave={e => e.currentTarget.style.background = "#1a56db"}
                  >
                    Open Official Portal ↗
                  </a>
                </div>
              );
            })}
          </div>
        )}
      </div>

      {/* Footer */}
      <footer style={{ background: theme.card, borderTop: `1px solid ${theme.border}`, padding: "1.5rem", textAlign: "center" }}>
        <p style={{ margin: 0, fontSize: 12.5, color: theme.sub }}>
          Built to make government services accessible to every Indian citizen. Not affiliated with any government body. All links point to official portals only.
        </p>
        <p style={{ margin: "6px 0 0", fontSize: 12, color: theme.sub, opacity: 0.7 }}>
          Suggest a service? Found a broken link? — Help us improve.
        </p>
      </footer>
    </div>
  );
}
